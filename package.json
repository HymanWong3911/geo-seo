{
  "name": "geo-seo",
  "version": "0.1.0",
  "private": true,
  "description": "GEO + SEO Search Visibility Console (内部工具 MVP)",
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "next build",
    "start": "next start -p 3010",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "tsx src/workers/index.ts",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "prisma:seed": "tsx src/prisma/seed.ts",
    "prisma:studio": "prisma studio --schema=src/prisma/schema.prisma",
    "audit": "tsx scripts/audit.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@sentry/nextjs": "^10.57.0",
    "@sentry/node": "^10.57.0",
    "@tanstack/react-table": "^8.20.0",
    "@tiptap/extension-link": "^2.5.0",
    "@tiptap/extension-placeholder": "^2.5.0",
    "@tiptap/pm": "^2.5.0",
    "@tiptap/react": "^2.5.0",
    "@tiptap/starter-kit": "^2.5.0",
    "antd": "^6.4.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cheerio": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^5.2.0",
    "ioredis": "^5.4.1",
    "lighthouse": "^12.2.1",
    "lucide-react": "^1.18.0",
    "next": "^14.2.5",
    "next-auth": "^5.0.0-beta.20",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.9.14",
    "playwright": "^1.46.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "robots-parser": "^3.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/diff": "^5.2.0",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.39",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "unrs-resolver"
