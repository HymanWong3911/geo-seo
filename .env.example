# ============= 数据库 =============
DATABASE_URL="postgresql://geo_seo:geo_seo_dev@localhost:5432/geo_seo"

# ============= 队列 =============
REDIS_URL="redis://localhost:6379"

# ============= LLM Provider 通用配置（用于分析、fallback）============
DEFAULT_LLM_PROVIDER="openai_compatible"
DEFAULT_LLM_MODEL="deepseek-chat"

# 第一类：云端官方
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""

# 第二类：OpenAI 兼容（覆盖 DeepSeek / MiniMax / Ollama / vLLM / 国内厂商）
LLM_BASE_URL="https://api.deepseek.com/v1"
LLM_API_KEY=""
LLM_MODELS="deepseek-chat,deepseek-reasoner"

# 第三类：自定义 HTTP
LLM_CUSTOM_HTTP_URL=""
LLM_CUSTOM_HTTP_AUTH=""

# ============= 真实 AI 搜索渠道（v1.1 D 组新增）============
# Perplexity（英文）
PERPLEXITY_API_KEY=""
PERPLEXITY_MODEL="llama-3.1-sonar-small-128k-online"

# Kimi / 月之暗面（中文）
KIMI_API_KEY=""
KIMI_BASE_URL="https://api.moonshot.cn/v1"
KIMI_MODEL="moonshot-v1-128k"

# 豆包 / 字节跳动（中文）
DOUBAO_API_KEY=""
DOUBAO_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
DOUBAO_MODEL="doubao-lite-32k"

# 渠道调度
GEO_DEFAULT_CHANNELS="perplexity,kimi,doubao"
GEO_FALLBACK_TO_LLM="true"
GEO_ANSWER_MAX_CHARS="8000"

# 预算与告警（v1.2 调整：暂时不设成本上限）
GEO_BUDGET_MONTHLY_CENTS="1000000"
GEO_BUDGET_ALERT_THRESHOLD="0.8"
GEO_BUDGET_HARD_LIMIT="false"

# ============= LLM 成本 =============
LLM_COST_INPUT_PER_1K="0.0014"
LLM_COST_OUTPUT_PER_1K="0.0028"

# ============= CMS 集成（v1.2 C 新增）============
CMS_BASE_URL="http://localhost:8080"
CMS_API_KEY=""

# ============= 跨平台分发（v1.2 F 新增）============
ZHIHU_API_TOKEN=""
WECHAT_MP_APP_ID=""
WECHAT_MP_APP_SECRET=""
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
NOTION_API_KEY=""

# ============= 告警（飞书 / 企微 / 邮件）============
ALERT_FEISHU_WEBHOOK_URL=""
ALERT_WECOM_WEBHOOK_URL=""

ALERT_SMTP_HOST="localhost"
ALERT_SMTP_PORT="1025"
ALERT_SMTP_USER=""
ALERT_SMTP_PASS=""
ALERT_SMTP_FROM="noreply@example.com"
ALERT_SMTP_TO="ops@example.com"

ALERT_DEDUPE_WINDOW_MIN="5"
ALERT_DAILY_SUMMARY_CRON="0 9 * * *"

# ============= 数据保留 =============
RETENTION_GEO_RESULT_MONTHS="12"
RETENTION_PAGE_AUDIT_MONTHS="12"
RETENTION_AUDIT_LOG_MONTHS="6"
RETENTION_CLEANUP_CRON="0 3 1 * *"

# ============= 应用 =============
APP_BASE_URL="http://localhost:3000"
AUTH_SECRET="replace_me_with_32_bytes_random_secret"
SESSION_TTL_HOURS="24"

# 时区（v1.1 G 组新增）
TZ="Asia/Shanghai"

# ============= Seed =============
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="Admin@2026"

# ===========================================
# GEO 搜索渠道配置
# ===========================================
# Perplexity（英文搜索，真实联网）
# 申请地址：https://www.perplexity.ai/settings/api
# 模型：llama-3.1-sonar-small-128k-online（推荐，免费额度）
#      或 llama-3.1-sonar-large-128k-online（付费）
# PERPLEXITY_API_KEY="pplx-xxxx"
# PERPLEXITY_MODEL="llama-3.1-sonar-small-128k-online"

# Kimi（中文搜索，通过 ARK Coding Plan）
# 如果有 ARK_API_KEY，可以留空（会自动复用）
# 如果用 moonshot.cn 直连，填这里
# KIMI_API_KEY=""
# KIMI_BASE_URL=""
# KIMI_MODEL=""

# 豆包（中文搜索，通过 ARK Coding Plan）
# 如果有 ARK_API_KEY，可以留空（会自动复用）
# 如果用 ARK 业务 API，填这里
# DOUBAO_API_KEY=""
# DOUBAO_BASE_URL=""
# DOUBAO_MODEL=""

# LLM Fallback（所有渠道失败时的兜底）
# 当没有配置任何 GEO 渠道时，使用 LLM 模拟搜索
# GEO_FALLBACK_TO_LLM="true"

# ===========================================
# Sentry 错误监控（可选）
# ===========================================
# 申请地址：https://sentry.io
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="geo-seo-web"
# SENTRY_AUTH_TOKEN="sntrys_xxxx"  # 在 Sentry 设置页面生成
# SENTRY_DSN=""  # 在项目设置中获取

# 是否启用 Sentry（生产环境自动启用）
# SENTRY_ENABLED="true"
